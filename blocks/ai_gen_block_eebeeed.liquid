{% doc %}
  @prompt
    生成一个顾客好评板块
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-testimonials-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .ai-testimonials-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-family: var(--font-heading-family);
  }

  .ai-testimonials-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.8;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-stars-{{ ai_gen_id }} svg {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: currentColor;
  }

  .ai-testimonial-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: {{ block.settings.avatar_placeholder_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-avatar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.avatar_size | divided_by: 2 }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-testimonial-author-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ai-testimonial-author-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_name_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-testimonial-author-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_title_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-testimonials-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-testimonials-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 16px;
    }
  }
{% endstyle %}

<div class="ai-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-testimonials-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-testimonials-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-testimonials-subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign review_enabled_key = 'review_' | append: i | append: '_enabled'
          assign review_text_key = 'review_' | append: i | append: '_text'
          assign review_rating_key = 'review_' | append: i | append: '_rating'
          assign author_name_key = 'author_' | append: i | append: '_name'
          assign author_title_key = 'author_' | append: i | append: '_title'
          assign author_image_key = 'author_' | append: i | append: '_image'

          assign review_enabled = block.settings[review_enabled_key]
          assign review_text = block.settings[review_text_key]
          assign review_rating = block.settings[review_rating_key]
          assign author_name = block.settings[author_name_key]
          assign author_title = block.settings[author_title_key]
          assign author_image = block.settings[author_image_key]
        %}

        {% if review_enabled %}
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            {% if block.settings.show_stars %}
              <div class="ai-testimonial-stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  {% if star <= review_rating %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}

            {% if review_text != blank %}
              <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ review_text }}</p>
            {% endif %}

            <div class="ai-testimonial-author-{{ ai_gen_id }}">
              <div class="ai-testimonial-avatar-{{ ai_gen_id }}">
                {% if author_image %}
                  <img
                    src="{{ author_image | image_url: width: 100 }}"
                    alt="{{ author_name | escape }}"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {% else %}
                  <div class="ai-testimonial-avatar-placeholder-{{ ai_gen_id }}">
                    {% if author_name != blank %}
                      {{ author_name | slice: 0 }}
                    {% else %}
                      ?
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="ai-testimonial-author-info-{{ ai_gen_id }}">
                {% if author_name != blank %}
                  <p class="ai-testimonial-author-name-{{ ai_gen_id }}">{{ author_name }}</p>
                {% endif %}
                {% if author_title != blank %}
                  <p class="ai-testimonial-author-title-{{ ai_gen_id }}">{{ author_title }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

