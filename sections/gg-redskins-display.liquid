{{ 'gg-redskins-display.css' | asset_url | stylesheet_tag }}
{{ 'quick-add.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>

<div class="gg-redskins-display page-width">
  <div class="gg-redskins-header">
    <h2 class="gg-redskins-heading">
      <span>{{ section.settings.heading_line_1 }}</span>
      <span>{{ section.settings.heading_line_2 }}</span>
    </h2>
    <div class="gg-redskins-header-right">
      <p class="gg-redskins-subheading">{{ section.settings.subheading }}</p>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="button gg-redskins-button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="gg-redskins-grid" id="gg-redskins-grid-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="gg-redskins-item {% if forloop.index > 8 %}hidden-desktop{% endif %} {% if forloop.index > 4 %}hidden-mobile{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.product != blank %}
          <div class="quick-add no-js-hidden">
            {%- assign card_product = block.settings.product -%}
            <modal-opener data-modal="#QuickAdd-{{ card_product.id }}">
              <button
                id="QuickAdd-{{ card_product.id }}-submit"
                type="button"
                class="gg-redskins-link"
                aria-haspopup="dialog"
                aria-labelledby="QuickAdd-{{ card_product.id }}-submit"
                data-product-url="{{ card_product.url }}"
                style="background: none; border: none; padding: 0; width: 100%; height: 100%; display: block;"
              >
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'gg-redskins-image' }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
                <div class="gg-redskins-overlay">
                  <span class="gg-redskins-hover-text">{{ block.settings.hover_title }}</span>
                  <div class="loading__spinner hidden">
                     <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                       <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                     </svg>
                   </div>
                </div>
                <div class="gg-redskins-icon">
                   {% render 'icon-instagram' %}
                </div>
              </button>
            </modal-opener>
            <quick-add-modal id="QuickAdd-{{ card_product.id }}" class="quick-add-modal">
              <div
                role="dialog"
                aria-label="{{ 'products.product.choose_product_options' | t: product_name: card_product.title | escape }}"
                aria-modal="true"
                class="quick-add-modal__content global-settings-popup"
                tabindex="-1"
              >
                <button
                  id="ModalClose-{{ card_product.id }}"
                  type="button"
                  class="quick-add-modal__toggle"
                  aria-label="{{ 'accessibility.close' | t }}"
                >
                  {{- 'icon-close.svg' | inline_asset_content -}}
                </button>
                <div id="QuickAddInfo-{{ card_product.id }}" class="quick-add-modal__content-info"></div>
              </div>
            </quick-add-modal>
          </div>
        {% else %}
          <a href="{{ block.settings.link }}" class="gg-redskins-link">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'gg-redskins-image' }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
            <div class="gg-redskins-overlay">
              <span class="gg-redskins-hover-text">{{ block.settings.hover_title }}</span>
            </div>
            <div class="gg-redskins-icon">
               {% render 'icon-instagram' %}
            </div>
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div class="gg-redskins-load-more {% if section.blocks.size <= 8 %}hidden-desktop{% endif %} {% if section.blocks.size <= 4 %}hidden-mobile{% endif %}">
    <button class="button button--secondary" id="gg-redskins-toggle-{{ section.id }}" onclick="toggleRedskins('{{ section.id }}')" data-state="more">Load More</button>
  </div>
</div>

<script>
  function toggleRedskins(sectionId) {
    const grid = document.getElementById('gg-redskins-grid-' + sectionId);
    const button = document.getElementById('gg-redskins-toggle-' + sectionId);
    const state = button.getAttribute('data-state');

    if (state === 'more') {
      // Show all
      const hiddenDesktop = grid.querySelectorAll('.hidden-desktop');
      hiddenDesktop.forEach(item => {
        item.classList.remove('hidden-desktop');
        item.classList.add('was-hidden-desktop');
      });
      
      const hiddenMobile = grid.querySelectorAll('.hidden-mobile');
      hiddenMobile.forEach(item => {
        item.classList.remove('hidden-mobile');
        item.classList.add('was-hidden-mobile');
      });

      button.innerText = 'Show Less';
      button.setAttribute('data-state', 'less');
    } else {
      // Hide back to default
      const wasHiddenDesktop = grid.querySelectorAll('.was-hidden-desktop');
      wasHiddenDesktop.forEach(item => {
        item.classList.remove('was-hidden-desktop');
        item.classList.add('hidden-desktop');
      });
      
      const wasHiddenMobile = grid.querySelectorAll('.was-hidden-mobile');
      wasHiddenMobile.forEach(item => {
        item.classList.remove('was-hidden-mobile');
        item.classList.add('hidden-mobile');
      });

      button.innerText = 'Load More';
      button.setAttribute('data-state', 'more');
    }
  }
</script>

{% schema %}
{
  "name": "GG-红人展示组件",
  "settings": [
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Big Title Line 1",
      "default": "#Never Stop"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Big Title Line 2",
      "default": "Exploring"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Small Title",
      "default": "@Alpargali"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "FOLLOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "redskin_display",
      "name": "GG-红人展示模块",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product (for Quick Add)"
        },
        {
          "type": "text",
          "id": "hover_title",
          "label": "Hover Title",
          "default": "Shop the Look"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (if no product selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GG-红人展示组件",
      "blocks": [
        {
          "type": "redskin_display"
        },
        {
          "type": "redskin_display"
        },
        {
          "type": "redskin_display"
        },
        {
          "type": "redskin_display"
        }
      ]
    }
  ]
}
{% endschema %}
