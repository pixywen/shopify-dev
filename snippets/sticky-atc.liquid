{% comment %}
  Sticky Add to Cart Bar - Mobile Only
  只在产品页显示，原始加购按钮滚出屏幕后自动出现
  插入方式：在 layout/theme.liquid 的 </body> 前加一行：
  {% render 'sticky-atc' %}
{% endcomment %}

{% if template == 'product' %}

<div id="sticky-atc-bar" aria-hidden="true">
  <button
    id="sticky-atc-btn"
    type="button"
    aria-label="{{ 'products.product.add_to_cart' | t }}"
  >
    <span id="sticky-atc-label">{{ 'products.product.add_to_cart' | t }}</span>
    <span id="sticky-atc-spinner" hidden>
      <svg aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 66 66">
        <circle stroke-width="6" cx="33" cy="33" r="30" fill="none" stroke="currentColor" stroke-dasharray="188.4" stroke-dashoffset="150" />
      </svg>
    </span>
  </button>
</div>

<style>
  /* 仅手机端显示 */
  @media screen and (min-width: 750px) {
    #sticky-atc-bar { display: none !important; }
  }

  #sticky-atc-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    padding: 12px 16px;
    padding-bottom: calc(12px + env(safe-area-inset-bottom));
    background: rgb(var(--color-background));
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.12);
    transform: translateY(100%);
    transition: transform 0.3s ease;
    pointer-events: none;
  }

  #sticky-atc-bar.is-visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  #sticky-atc-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 4.8rem;
    padding: 0 2rem;
    border: none;
    border-radius: var(--buttons-radius, 0);
    background-color: rgba(var(--color-button), var(--alpha-button-background, 1));
    color: rgb(var(--color-button-text));
    font: inherit;
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  #sticky-atc-btn:active {
    opacity: 0.85;
  }

  #sticky-atc-btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* 加载中旋转动画 */
  #sticky-atc-spinner svg {
    width: 2rem;
    height: 2rem;
    animation: sticky-spin 0.8s linear infinite;
  }

  @keyframes sticky-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
(function () {
  // 只在手机端执行
  if (window.innerWidth >= 750) return;

  document.addEventListener('DOMContentLoaded', function () {
    var bar     = document.getElementById('sticky-atc-bar');
    var btn     = document.getElementById('sticky-atc-btn');
    var label   = document.getElementById('sticky-atc-label');
    var spinner = document.getElementById('sticky-atc-spinner');

    if (!bar || !btn) return;

    // ── 1. 找原始加购按钮 ──────────────────────────────────────────
    function getOriginalBtn() {
      return (
        document.querySelector('button[id^="ProductSubmitButton"]') ||
        document.querySelector('.product-form__submit')
      );
    }

    // ── 2. 判断原始按钮是否在视口内 ────────────────────────────────
    function isOriginalBtnVisible() {
      var orig = getOriginalBtn();
      if (!orig) return true; // 找不到就保持隐藏
      var rect = orig.getBoundingClientRect();
      return rect.bottom > 0 && rect.top < window.innerHeight;
    }

    // ── 3. 同步按钮状态（售罄/不可用） ─────────────────────────────
    function syncBtnState() {
      var orig = getOriginalBtn();
      if (!orig) return;
      if (orig.disabled) {
        btn.disabled = true;
        label.textContent = orig.querySelector('span') 
          ? orig.querySelector('span').textContent.trim() 
          : orig.textContent.trim();
      } else {
        btn.disabled = false;
        label.textContent = {{ 'products.product.add_to_cart' | t | json }};
      }
    }

    // ── 4. 显示/隐藏 sticky bar ────────────────────────────────────
    function updateBarVisibility() {
      if (isOriginalBtnVisible()) {
        bar.classList.remove('is-visible');
        bar.setAttribute('aria-hidden', 'true');
      } else {
        syncBtnState();
        bar.classList.add('is-visible');
        bar.setAttribute('aria-hidden', 'false');
      }
    }

    // 节流：每 100ms 最多执行一次
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          updateBarVisibility();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // 初始检查
    updateBarVisibility();

    // ── 5. 点击 sticky 按钮 → 触发原始表单提交 ──────────────────
    btn.addEventListener('click', function () {
      var orig = getOriginalBtn();
      if (!orig || orig.disabled) return;

      // 显示加载状态
      label.hidden = true;
      spinner.hidden = false;
      btn.disabled = true;

      // 触发原始按钮点击（走主题本身的加购逻辑）
      orig.click();

      // 监听加购完成事件（Shopify 标准事件）
      var done = function () {
        label.hidden = false;
        spinner.hidden = true;
        btn.disabled = false;
        document.removeEventListener('cart:refresh', done);
        document.removeEventListener('cart:updated', done);
      };

      // 兼容不同主题的购物车更新事件
      document.addEventListener('cart:refresh', done, { once: true });
      document.addEventListener('cart:updated', done, { once: true });

      // 保底：3秒后恢复按钮，防止事件未触发时按钮卡死
      setTimeout(done, 3000);
    });

    // ── 6. 监听变体切换，同步按钮状态 ──────────────────────────────
    document.addEventListener('variant:changed', syncBtnState);
    document.addEventListener('variantChange', syncBtnState);

    // 用 MutationObserver 监听原始按钮的 disabled 属性变化
    var orig = getOriginalBtn();
    if (orig) {
      new MutationObserver(syncBtnState).observe(orig, {
        attributes: true,
        attributeFilter: ['disabled']
      });
    }
  });
})();
</script>

{% endif %}
