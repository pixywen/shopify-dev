        "collapsible_tab_yAPYME": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Details",
            "icon": "none",
            "content": "<h5>TRACE SERIES</h5><p>Performance inspired by species that still remain — quietly, rarely, and against the odds.</p><p>Built with lightweight snowflake-texture fabric and designed for movement, this piece reflects adaptation in motion: breathable, resilient, and made to endure everyday environments.</p><h5><strong>Quick-Drying & Breathable</strong></h5><p>Engineered with a 95% polyester snowflake-texture fabric that promotes airflow and efficiently releases moisture.</p><h5>Active-Stretch Comfort</h5><p>A 5% spandex blend provides four-way stretch for unrestricted movement and a close, adaptive fit.</p><h5>Durable & Easy Care</h5><p>Resists pilling, wrinkling, and shrinking for dependable wear through repeated use.</p><h5>Abrasion Resistant</h5><p>Designed to maintain performance through changing conditions and constant movement.</p><h5>Everyday Ready</h5><p>Machine washable and easy to maintain.</p>",
            "page": "",
            "image_alt": "",
            "image_width": 50
          }
        },
