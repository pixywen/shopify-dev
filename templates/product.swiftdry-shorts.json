        "collapsible_tab_yAPYME": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Details",
            "icon": "none",
            "content": "<h5>Alpargali SwiftDry Shorts</h5><p>Built for heat, movement, and everyday adaptability.</p><p>Engineered with ultra-light 115gsm performance fabric and a micro-textured structure, these shorts are designed to stay breathable, dry fast, and move without restriction in changing environments.</p><p>Inspired by functional performance systems in nature, every detail is built to reduce resistance—heat, weight, and friction—so movement feels effortless from travel to training to daily wear.</p><h5>Quick-Drying & Breathable</h5><p>Micro-texture fabric with micro-ventilation channels enhances airflow and speeds up moisture release, keeping you dry and comfortable in heat and humidity.</p><h5>Cooling Touch Comfort</h5><p>Engineered with instant cooling-touch properties that help reduce heat buildup and deliver a refreshing feel on contact.</p><h5>Active 4-Way Stretch</h5><p>Made with 25% spandex for high elasticity and recovery, providing unrestricted movement for hiking, training, commuting, and travel.</p><h5>Ultra-Lightweight Construction</h5><p>At only 115gsm, the fabric minimizes weight on body for a barely-there wearing experience.</p><h5>Functional Storage System</h5><p>Multiple-pocket design including side pockets and a hidden rear zipper pocket for secure, stable storage on the move.</p><h5>Adaptive Waist Fit</h5><p>Elastic waistband with adjustable drawcord ensures a secure, flexible fit across different activities.</p><h5>Low-Light Visibility</h5><p>Reflective logo detail enhances visibility and safety in low-light environments.</p>",
            "page": "",
            "image_alt": "",
            "image_width": 50
          }
        },
        "collapsible_tab_GyWCqX": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Specs",
            "icon": "none",
            "content": "<ul><li>Fabric：75% Nylon / 25% Spandex</li><li>Weight：115gsm Ultra-Lightweight</li><li>Texture：Micro-Textured Airflow Structure</li><li>Stretch：4-Way High Elasticity</li><li>Breathability：High</li><li>Drying Speed：Fast-Dry</li><li>Cooling：Instant Cool Touch</li><li>Waist：Elastic + Adjustable Drawcord</li><li>Storage：Side Pockets + Rear Zipper Pocket + Hidden Pocket</li><li>Visibility：Reflective Logo Detail</li></ul>",
            "page": "",
            "image_alt": "",
            "image_width": 50
          }
        },
        "collapsible_tab_4bGyQa": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Care",
            "icon": "none",
            "content": "<ul><li>Wash gently</li><li>Do not bleach</li><li>Iron on low heat</li><li>Line dry in the shade</li><li>Do not dry clean</li><li>Wash separately, inside out</li><li>Do not soak</li></ul>",
